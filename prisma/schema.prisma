generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String      @id @default(uuid())
  email          String      @unique
  password       String
  fullName       String?     @map("full_name")
  profilePicture String?     @map("profile_picture")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  role           UserRole    @default(USER) @map("role")
  isBlocked      Boolean     @default(false) @map("is_blocked")
  bestResult     BestResult?
  reviews        Review[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model BestResult {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  bestFrontendScore Int @default(0) @map("best_frontend_score")
  bestBackendScore  Int @default(0) @map("best_backend_score")
  bestMobileScore   Int @default(0) @map("best_mobile_score")

  totalScore         Int       @default(0) @map("total_score")
  frontendAchievedAt DateTime? @map("frontend_achieved_at")
  backendAchievedAt  DateTime? @map("backend_achieved_at")
  mobileAchievedAt   DateTime? @map("mobile_achieved_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("best_results")
}

model Review {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  userFullName       String   @map("user_full_name")
  userProfilePicture String?  @map("user_profile_picture")
  text               String
  rating             Int      @default(5)
  isApproved         Boolean  @default(false) @map("is_approved")
  createdAt          DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
